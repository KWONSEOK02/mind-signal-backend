{
  "name": "mind-signal-backend",
  "version": "1.0.0",
  "main": "dist/01-app/app.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "open-cli http://localhost:5000/api-docs && ts-node-dev --respawn --transpile-only -r tsconfig-paths/register ./src/01-app/app.ts",
    "build": "tsc && tsc-alias",
    "start": "node -r tsconfig-paths/register ./dist/01-app/app.js",
    "test": "jest",
    "test:watch": "cross-env NODE_ENV=test jest --watchAll",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "seed": "ts-node -r tsconfig-paths/register ./src/07-shared/lib/seeds/seed.ts",
    "infra:up": "docker-compose up -d",
    "infra:down": "docker-compose down",
    "test:redis": "docker exec -it mind-signal-redis redis-cli psubscribe mind-signal:*",
    "data:run": "cd ../mind-signal-data-engine && python -m core.streamer",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "depcruise": "depcruise src --config .dependency-cruiser.cjs",
    "verify": "npm run format:check && npm run typecheck && npm run depcruise && npm run lint && npm run test && npm run build",
    "commitlint": "commitlint --from=HEAD~1 --to=HEAD --verbose"
  },
  "description": "Mind Signal Project Backend",
  "dependencies": {
    "@google/genai": "^1.34.0",
    "@google/generative-ai": "^0.24.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.1.1",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.4",
    "pdf-parse": "^2.4.5",
    "redis": "^5.10.0",
    "socket.io": "^4.8.3",
    "supertest": "^7.1.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "ts-jest": "^29.4.6",
    "tsconfig-paths": "^4.2.0",
    "zod": "^4.3.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@faker-js/faker": "^10.1.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.3",
    "@types/nodemailer": "^7.0.11",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "dependency-cruiser": "^17.3.10",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^17.0.0",
    "jest": "^30.2.0",
    "open-cli": "^8.0.0",
    "prettier": "^3.7.4",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3"
  }
}
