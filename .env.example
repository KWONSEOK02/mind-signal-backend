# ======================
# Server
# ======================
PORT=5000
NODE_ENV=development

# ======================
# Database
# ======================
MONGODB_URI=mongodb+srv://<DB_USER>:<DB_PASSWORD>@todo-dev-cluster.1eldpej.mongodb.net/mind_signal_dev?retryWrites=true&w=majority

# ======================
# Authentication (JWT)
# ======================
JWT_SECRET_KEY=your_jwt_secret_key_here
# 토큰 수명 제어용
JWT_EXPIRES_IN=1d    

# ======================
# CORS 프론트 접근 제어용
# ======================
CORS_ORIGIN=http://localhost:3000

# ======================
# External APIs
# ======================
GOOGLE_API_KEY=your_google_api_key_here

# ======================
# File Upload 파일 저장 위치 제어용
# ======================
UPLOAD_DIR=uploads

# ======================
# mind-signal-data-engine 프로젝트 저장 위치 제어용
# ======================
DATA_ENGINE_PATH=../mind-signal-data-engine
PUBLIC_BASE_URL=http://localhost:5000

#======================
# mind-signal-data-engine 데이터 호출 베이스 url
# ======================
DATA_ENGINE_URL=<mind-signal-data-engine 데이터 호출 베이스 url>

# ======================
# Python EEG 엔진 바이너리 경로 (mind-signal conda 환경)
# ======================
DATA_ENGINE_PYTHON=C:\Users\<YOUR_USERNAME>\.conda\envs\mind-signal\python.exe

# ======================
# 소셜 로그인 — Google (Google Cloud Console > OAuth 2.0 클라이언트 ID)
# ======================
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# ======================
# 소셜 로그인 — Kakao (Kakao Developers > 내 애플리케이션 > 앱 키)
# ======================
KAKAO_CLIENT_ID=your_kakao_rest_api_key_here
KAKAO_CLIENT_SECRET=your_kakao_client_secret_here
KAKAO_REDIRECT_URI=http://localhost:3000/auth/callback
