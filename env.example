# ======================
# Server
# ======================
PORT=5000
NODE_ENV=development

# ======================
# Database
# ======================
MONGODB_URI=mongodb+srv://<DB_USER>:<DB_PASSWORD>@todo-dev-cluster.1eldpej.mongodb.net/mind_signal_dev?retryWrites=true&w=majority

# ======================
# Authentication (JWT)
# ======================
JWT_SECRET_KEY=your_jwt_secret_key_here
# 토큰 수명 제어용
JWT_EXPIRES_IN=1d    

# ======================
# CORS 프론트 접근 제어용
# ======================
CORS_ORIGIN=http://localhost:3000

# ======================
# External APIs
# ======================
GOOGLE_API_KEY=your_google_api_key_here

# ======================
# File Upload 파일 저장 위치 제어용
# ======================
UPLOAD_DIR=uploads

# ======================
# mind-signal-data-engine 프로젝트 저장 위치 제어용
# ======================
DATA_ENGINE_PATH=../mind-signal-data-engine

#======================
# mind-signal-data-engine 데이터 호출 베이스 url
# ======================
DATA_ENGINE_URL=<mind-signal-data-engine 데이터 호출 베이스 url>

# ======================
# Gmail Configuration (for /chat/ask)
# ======================
GMAIL_USER=your-email@gmail.com
GMAIL_PASS=your-app-password

# ======================
# Daum Configuration (for /chat/ask)
# ======================
DAUM_USER=your-email@daum.net
DAUM_PASS=your-app-password

# ======================
# 문의 담당자 이메일
# ======================
ASK_USER=mks004@neurosignal.kr
